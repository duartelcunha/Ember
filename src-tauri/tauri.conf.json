{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ember",
  "version": "../package.json",
  "identifier": "com.deleg8lab.ember",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "url": "overlay.html",
        "create": false,
        "width": 300,
        "height": 140,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "visible": false
      },
      {
        "label": "settings",
        "url": "settings.html",
        "create": false,
        "title": "Ember",
        "width": 920,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true },
      "nsis": { "installMode": "currentUser" }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE4M0NBMzAwOUVEODQwNzAKUldSd1FOaWVBS004cUhYcVdGaW1aL1duOUV3dkVSZHVlaG1Ld0F6WlJRdk12ODMrMUJBdnVEejMK",
      "endpoints": ["https://github.com/duartelcunha/ember/releases/latest/download/latest.json"],
      "windows": { "installMode": "passive" }
    }
  }
}
