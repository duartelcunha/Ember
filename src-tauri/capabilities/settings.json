{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "settings",
  "description": "Permissoes da janela de definicoes.",
  "windows": ["settings"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-hide",
    "core:window:allow-start-dragging",
    "autostart:default",
    "updater:default",
    "process:allow-restart",
    "dialog:allow-open"
  ]
}
